# Required
DISCORD_WEBHOOK_URL=         # Discord channel webhook URL
GOOGLE_OAUTH_TOKEN=          # OAuth user token JSON (run auth.py to generate)
GECKOTERMINAL_API_KEY=       # CoinGecko Pro Basic tier; lets us hit 300 req/min on /onchain endpoints
XAI_API_KEY=                 # xAI Grok API key (Responses API + x_search/web_search tools)

# Optional
ALCHEMY_API_KEY=             # for Base on-chain decimals fallback
HELIUS_API_KEY=              # for Solana on-chain decimals fallback
GOOGLE_SHEETS_CREDENTIALS=   # service-account JSON path or contents; only used if GOOGLE_OAUTH_TOKEN is unset (fallback code path)
